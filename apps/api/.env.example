# MercadoPro API — Variables de entorno
# Copiar como .env y completar con valores reales

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/mercadopro"

# JWT Secret (cambiar en producción)
JWT_SECRET="cambiar-en-produccion-usar-valor-aleatorio-largo"

# Servidor
PORT=3001
HOST=0.0.0.0

# CORS — dominio del frontend
CORS_ORIGIN="https://tu-dominio.netlify.app"

# Entorno
NODE_ENV=development
